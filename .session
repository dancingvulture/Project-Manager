let s:l = 12 - ((8 * winheight(0) + 5) / 10)
if s:l < 1 | let s:l = 1 | endif
keepjumps exe s:l
normal! zt
keepjumps 12
normal! 050|
wincmd w
4wincmd w
exe 'vert 1resize ' . ((&columns * 81 + 122) / 245)
exe '2resize ' . ((&lines * 61 + 37) / 74)
exe 'vert 2resize ' . ((&columns * 81 + 122) / 245)
